export module coregear.fsim.riscv;

export import :extensions;
export import :regs;

import coregear.fsim.sim;

import coregear.common;
import coregear.utility;

import std;

export namespace cg::riscv {

using inst_t = word_t;

#define CG_FSIM_RISCV_RV32I_OPOCDES(X)                                         \
  /* arithmetic */                                                             \
  X(ADD, 0b0110011u, RTYPE, 0b000u, 0b0000000u)                                \
  X(SUB, 0b0110011u, RTYPE, 0b000u, 0b0100000u)                                \
  X(OR, 0b0110011u, RTYPE, 0b110u, 0b0000000u)                                 \
  X(XOR, 0b0110011u, RTYPE, 0b100u, 0b0000000u)                                \
  X(AND, 0b0110011u, RTYPE, 0b111u, 0b0000000u)                                \
  X(SRL, 0b0110011u, RTYPE, 0b101u, 0b0000000u)                                \
  X(SLL, 0b0110011u, RTYPE, 0b001u, 0b0000000u)                                \
  X(SRA, 0b0110011u, RTYPE, 0b101u, 0b0100000u)                                \
  /* arithmetic with immediate */                                              \
  X(ADDI, 0b0010011u, ITYPE, 0b000u, no_funct7)                                \
  X(ORI, 0b0010011u, ITYPE, 0b110u, no_funct7)                                 \
  X(XORI, 0b0010011u, ITYPE, 0b100u, no_funct7)                                \
  X(ANDI, 0b0010011u, ITYPE, 0b111u, no_funct7)                                \
  X(SRLI, 0b0010011u, ITYPE, 0b101u, no_funct7)                                \
  X(SLLI, 0b0010011u, ITYPE, 0b001u, no_funct7)                                \
  X(SRAI, 0b0010011u, ITYPE, 0b101u, no_funct7)                                \
  /* jumps and calls */                                                        \
  X(JAL, 0b1101111u, JTYPE, no_funct3, no_funct7)                              \
  X(JALR, 0b1100111u, ITYPE, 0b000u, no_funct7)                                \
  X(BEQ, 0b1100011u, BTYPE, 0b000u, no_funct7)                                 \
  X(BNE, 0b1100011u, BTYPE, 0b001u, no_funct7)                                 \
  X(BLT, 0b1100011u, BTYPE, 0b100u, no_funct7)                                 \
  X(BGE, 0b1100011u, BTYPE, 0b101u, no_funct7)                                 \
  X(BLTU, 0b1100011u, BTYPE, 0b110u, no_funct7)                                \
  X(BGEU, 0b1100011u, BTYPE, 0b111u, no_funct7)                                \
  /* loads/sotres */                                                           \
  X(LB, 0b0000011u, ITYPE, 0b000u, no_funct7)                                  \
  X(LH, 0b0000011u, ITYPE, 0b001u, no_funct7)                                  \
  X(LW, 0b0000011u, ITYPE, 0b010u, no_funct7)                                  \
  X(LBU, 0b0000011u, ITYPE, 0b100u, no_funct7)                                 \
  X(LHU, 0b0000011u, ITYPE, 0b101u, no_funct7)                                 \
  X(SB, 0b0100011u, STYPE, 0b000u, no_funct7)                                  \
  X(SH, 0b0100011u, STYPE, 0b001u, no_funct7)                                  \
  X(SW, 0b0100011u, STYPE, 0b010u, no_funct7)                                  \
  /* data flow */                                                              \
  X(SLT, 0b0110011u, RTYPE, 0b010u, 0b0000000u)                                \
  X(SLTU, 0b0110011u, RTYPE, 0b011u, 0b0000000u)                               \
  X(SLTI, 0b0010011u, ITYPE, 0b010u, no_funct7)                                \
  X(SLTIU, 0b0010011u, ITYPE, 0b100u, no_funct7)                               \
  /* upper immediate */                                                        \
  X(LUI, 0b0110111u, UTYPE, no_funct3, no_funct7)                              \
  X(AUIPC, 0b0010111u, UTYPE, no_funct3, no_funct7)                            \
  /* special ones */                                                           \
  X(FENCE, 0b0001111u, ITYPE, 0b010u, 0b0000000u)                              \
  X(ECALL, 0b1110011u, SYSTYPE, no_funct3, 0b000000000000u)                    \
  X(EBREAK, 0b1110011u, SYSTYPE, no_funct3, 0b000000000001u)

#define CG_FSIM_RISCV_ZICSR_OPOCDES(X)                                         \
  /* zicsr */                                                                  \
  X(CSRRW, 0b1110011u, CSRTYPE, 0b001u, no_funct7)                             \
  X(CSRRS, 0b1110011u, CSRTYPE, 0b010u, no_funct7)                             \
  X(CSRRC, 0b1110011u, CSRTYPE, 0b011u, no_funct7)                             \
  X(CSRRWI, 0b1110011u, CSRITYPE, 0b101u, no_funct7)                           \
  X(CSRRSI, 0b1110011u, CSRITYPE, 0b110u, no_funct7)                           \
  X(CSRRCI, 0b1110011u, CSRITYPE, 0b111u, no_funct7)

#define CG_FSIM_RISCV_RV32M_OPOCDES(X)                                         \
  /* rv32m */                                                                  \
  X(MUL, 0b0110011u, RTYPE, 0b000u, 0b0000001)                                 \
  X(MULH, 0b0110011u, RTYPE, 0b001u, 0b0000001)                                \
  X(MULHSU, 0b0110011u, RTYPE, 0b010u, 0b0000001)                              \
  X(MULHU, 0b0110011u, RTYPE, 0b011u, 0b0000001)                               \
  X(DIV, 0b0110011u, RTYPE, 0b100u, 0b0000001)                                 \
  X(DIVU, 0b0110011u, RTYPE, 0b101u, 0b0000001)                                \
  X(REM, 0b0110011u, RTYPE, 0b110u, 0b0000001)                                 \
  X(REMU, 0b0110011u, RTYPE, 0b111u, 0b0000001)

#define CG_FSIM_RISCV_OPCODE_ITEM(opc, ...) opc,

enum class opcode_t {
  CG_FSIM_RISCV_RV32I_OPOCDES(CG_FSIM_RISCV_OPCODE_ITEM)
      CG_FSIM_RISCV_RV32M_OPOCDES(CG_FSIM_RISCV_OPCODE_ITEM)
          CG_FSIM_RISCV_ZICSR_OPOCDES(CG_FSIM_RISCV_OPCODE_ITEM)
};

struct no_funct_t final {};

inline constexpr no_funct_t no_funct;

template <size_t bitwidth, size_t offset> class funct_t final {
  inst_t data;
  bool has_funct = true;

public:
  consteval funct_t(no_funct_t) noexcept : data(0), has_funct(false) {}

  consteval funct_t(inst_t funct) noexcept {
    *this = funct_t(std::bitset<bitwidth>(funct));
  }

  consteval funct_t(std::bitset<bitwidth> funct) noexcept
      : data(funct.to_ulong() << offset) {}

  consteval operator inst_t() const noexcept { return data; }

  consteval inst_t filter() noexcept {
    if (!has_funct)
      return 0;
    return std::bitset<bitwidth>().set().to_ullong() << offset;
  }
};

using funct3 = funct_t<3, 12>;
using funct7 = funct_t<7, 25>;
using funct12 = funct_t<12, 20>;
using opcode_encoding_t = funct_t<7, 0>;

inline constexpr auto no_funct3 = funct3(no_funct);
inline constexpr auto no_funct7 = funct7(no_funct);

#define CG_FSIM_RISCV_OPC_BITS_ITEM(opc, bits, ...)                            \
  case opcode_t::opc:                                                          \
    return bits;

inline consteval opcode_encoding_t opcode_bits(opcode_t opcode) {
  switch (opcode) {
    CG_FSIM_RISCV_RV32I_OPOCDES(CG_FSIM_RISCV_OPC_BITS_ITEM)
    CG_FSIM_RISCV_RV32M_OPOCDES(CG_FSIM_RISCV_OPC_BITS_ITEM)
    CG_FSIM_RISCV_ZICSR_OPOCDES(CG_FSIM_RISCV_OPC_BITS_ITEM)
  default:
    throw unknown_opcode(opcode);
  }
};

enum class encoding_t {
  RTYPE,
  ITYPE,
  STYPE,
  BTYPE,
  UTYPE,
  JTYPE,
  SYSTYPE,
  CSRTYPE,
  CSRITYPE,
};

#define CG_FSIM_RISCV_OPC_ENCODING_ITEM(opc, _, encoding, ...)                 \
  case opcode_t::opc:                                                          \
    return encoding_t::encoding;

inline constexpr encoding_t encoding4opcode(opcode_t opcode) {
  switch (opcode) {
    CG_FSIM_RISCV_RV32I_OPOCDES(CG_FSIM_RISCV_OPC_ENCODING_ITEM)
    CG_FSIM_RISCV_RV32M_OPOCDES(CG_FSIM_RISCV_OPC_ENCODING_ITEM)
    CG_FSIM_RISCV_ZICSR_OPOCDES(CG_FSIM_RISCV_OPC_ENCODING_ITEM)
  default:
    throw unknown_opcode(opcode);
  }
}

class gpr_operand_info_t {
  bool dst;

public:
  constexpr gpr_operand_info_t(bool is_dst) noexcept : dst(is_dst) {}

  constexpr auto is_dst() const noexcept { return dst; }
};

class imm_operand_info_t {
public:
  constexpr imm_operand_info_t() noexcept {}
};

class csr_operand_info_t {
public:
  constexpr csr_operand_info_t() noexcept {}
};

using operand_info_t =
    cg::operand_info_t<gpr_operand_info_t, imm_operand_info_t,
                       csr_operand_info_t>;

class gpr_operand_t final : private gpr_operand_info_t {
public:
  using op_info_t = gpr_operand_info_t;

private:
  reg_id_t id;

public:
  constexpr gpr_operand_t(gpr_operand_info_t op_info, reg_id_t reg_id)
      : gpr_operand_info_t(op_info), id(reg_id) {
    CG_ASSERT(id < gpr_reg_class_t::n_regs);
  }

  constexpr gpr_operand_t(gpr_operand_info_t op_info, gpr_t reg_id)
      : gpr_operand_info_t(op_info), id(static_cast<reg_id_t>(reg_id)) {
    CG_ASSERT(id < gpr_reg_class_t::n_regs);
  }

  constexpr gpr_operand_t(gpr_operand_info_t op_info, gpr_abi_t reg_id)
      : gpr_operand_info_t(op_info), id(static_cast<reg_id_t>(reg_id)) {
    CG_ASSERT(id < gpr_reg_class_t::n_regs);
  }

  constexpr auto get_reg_id() const { return id; }

  using gpr_operand_info_t::is_dst;
};

class imm_operand_t final : private imm_operand_info_t {
public:
  using op_info_t = imm_operand_info_t;

private:
  reg_t imm_data;

public:
  constexpr imm_operand_t(imm_operand_info_t info, reg_t imm)
      : imm_operand_info_t(info), imm_data(imm) {}

  constexpr auto imm() const noexcept { return imm_data; }
};

enum class csr_t {};

class csr_operand_t final : private csr_operand_info_t {
public:
  using op_info_t = csr_operand_info_t;

private:
  csr_t csr_data;

public:
  constexpr csr_operand_t(csr_operand_info_t info, csr_t csr)
      : csr_operand_info_t(info), csr_data(csr) {}

  constexpr auto csr() const noexcept { return csr_data; }
};

using operand_t = cg::operand_t<gpr_operand_t, imm_operand_t, csr_operand_t>;

class gpr_operand_matcher_t {
public:
  using inst_type = inst_t;
  using extract_type = reg_id_t;

private:
  inst_t filter_mask;
  size_t offset;

public:
  gpr_operand_matcher_t(inst_t filter, reg_id_t offset) noexcept
      : filter_mask(filter), offset(offset) {}

  size_t extract(inst_t inst) const noexcept {
    return (inst & filter_mask) >> offset;
  }
};

class imm_operand_matcher_t {
public:
  using inst_type = inst_t;
  using extract_type = reg_t;

  enum class bit_map_t {
    TO_0 = 0,
    TO_1 = 1,
    TO_2 = 2,
    TO_3 = 3,
    TO_4 = 4,
    TO_5 = 5,
    TO_6 = 6,
    TO_7 = 7,
    TO_8 = 8,
    TO_9 = 9,
    TO_10 = 10,
    TO_11 = 11,
    TO_12 = 12,
    TO_13 = 13,
    TO_14 = 14,
    TO_15 = 15,
    TO_16 = 16,
    TO_17 = 17,
    TO_18 = 18,
    TO_19 = 19,
    TO_20 = 20,
    TO_21 = 21,
    TO_22 = 22,
    TO_23 = 23,
    TO_24 = 24,
    TO_25 = 25,
    TO_26 = 26,
    TO_27 = 27,
    TO_28 = 28,
    TO_29 = 29,
    TO_30 = 30,
    TO_31 = 31,
    ALWAYS_0,
  };

private:
  std::array<bit_map_t, num_bits_in_inst> bit_mapping;

  static bool get_bit(inst_t val, bit_map_t idx) {
    constexpr size_t bitwidth = num_bits_in_inst;
    if (idx == bit_map_t::ALWAYS_0)
      return 0;
    return std::bitset<bitwidth>(val)[static_cast<size_t>(idx)];
  }

  static reg_t set_bit(reg_t val, size_t idx, bool bit) {
    constexpr size_t bitwidth = xlen;
    std::bitset<bitwidth> bitval(std::bit_cast<ureg_t>(val));
    bitval[static_cast<size_t>(idx)] = bit;
    ureg_t uval = bitval.to_ulong();
    return std::bit_cast<reg_t>(uval);
  }

public:
  imm_operand_matcher_t(std::array<bit_map_t, num_bits_in_inst> mapping)
      : bit_mapping{std::move(mapping)} {}

  reg_t extract(inst_t inst) const {
    reg_t imm = 0;
    for (auto [tgt_idx, src_idx] : utils::enumerate(bit_mapping))
      imm = set_bit(imm, tgt_idx, get_bit(inst, src_idx));
    return imm;
  }

  static const std::unordered_map<encoding_t, imm_operand_matcher_t> per_enc;
};

