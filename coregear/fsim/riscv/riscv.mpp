class csr_operand_matcher_t {
public:
  using inst_type = inst_t;
  using extract_type = csr_t;

  consteval csr_operand_matcher_t() noexcept {}

  csr_t extract(inst_t inst) const noexcept {
    constexpr size_t bitwidth = 12;
    constexpr size_t offset = 20;
    constexpr inst_t filter_mask = std::bitset<bitwidth>().set().to_ullong()
                                   << offset;

    return static_cast<csr_t>((inst & filter_mask) >> offset);
  }
};

using operand_matcher_t =
    cg::operand_matcher_t<gpr_operand_matcher_t, imm_operand_matcher_t,
                          csr_operand_matcher_t>;

} // namespace cg::riscv

#define CG_RISCV_MAP_OP_INFO_TO_OP(op_info, op, matcher)                       \
  template <> struct cg::op_info_traits<cg::riscv::op_info> {                  \
    using op_type = cg::riscv::op;                                             \
    using matcher_type = cg::riscv::matcher;                                   \
  }

CG_RISCV_MAP_OP_INFO_TO_OP(gpr_operand_info_t, gpr_operand_t,
                           gpr_operand_matcher_t);
CG_RISCV_MAP_OP_INFO_TO_OP(imm_operand_info_t, imm_operand_t,
                           imm_operand_matcher_t);
CG_RISCV_MAP_OP_INFO_TO_OP(csr_operand_info_t, csr_operand_t,
                           csr_operand_matcher_t);

#undef CG_RISCV_MAP_OP_INFO_TO_OP

export namespace cg::riscv {

struct operand_description_tr {
  using op_info_t = operand_info_t;
  using op_t = operand_t;
  using op_matcher_t = operand_matcher_t;

  using per_enc_t = std::unordered_map<
      encoding_id_t,
      std::vector<cg::operand_description_t<operand_description_tr>>>;

  static const per_enc_t per_enc;
};

using operand_description_t = cg::operand_description_t<operand_description_tr>;

inline const typename operand_description_tr::per_enc_t
    operand_description_tr::per_enc = {
        {static_cast<encoding_id_t>(encoding_t::RTYPE),
         {
             {gpr_operand_info_t(true), gpr_operand_matcher_t(0x00000f80, 7)},
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x000f8000, 15)},
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x01f00000, 20)},
         }},
        {static_cast<encoding_id_t>(encoding_t::ITYPE),
         {
             {gpr_operand_info_t(true), gpr_operand_matcher_t(0x00000f80, 7)},
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x000f8000, 15)},
             {imm_operand_info_t(),
              imm_operand_matcher_t::per_enc.at(encoding_t::ITYPE)},
         }},
        {static_cast<encoding_id_t>(encoding_t::STYPE),
         {
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x000f8000, 15)},
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x01f00000, 20)},
             {imm_operand_info_t(),
              imm_operand_matcher_t::per_enc.at(encoding_t::STYPE)},
         }},
        {static_cast<encoding_id_t>(encoding_t::BTYPE),
         {
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x000f8000, 15)},
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x01f00000, 20)},
             {imm_operand_info_t(),
              imm_operand_matcher_t::per_enc.at(encoding_t::BTYPE)},
         }},
        {static_cast<encoding_id_t>(encoding_t::UTYPE),
         {
             {gpr_operand_info_t(true), gpr_operand_matcher_t(0x00000f80, 7)},
             {imm_operand_info_t(),
              imm_operand_matcher_t::per_enc.at(encoding_t::UTYPE)},
         }},
        {static_cast<encoding_id_t>(encoding_t::JTYPE),
         {
             {gpr_operand_info_t(true), gpr_operand_matcher_t(0x00000f80, 7)},
             {imm_operand_info_t(),
              imm_operand_matcher_t::per_enc.at(encoding_t::JTYPE)},
         }},
        {static_cast<encoding_id_t>(encoding_t::SYSTYPE), {}},
        {static_cast<encoding_id_t>(encoding_t::CSRTYPE),
         {
             {gpr_operand_info_t(true), gpr_operand_matcher_t(0x00000f80, 7)},
             {gpr_operand_info_t(false), gpr_operand_matcher_t(0x000f8000, 15)},
             {csr_operand_info_t(), csr_operand_matcher_t()},
         }},
        {static_cast<encoding_id_t>(encoding_t::CSRITYPE),
         {
             {gpr_operand_info_t(true), gpr_operand_matcher_t(0x00000f80, 7)},
             {imm_operand_info_t(),
              imm_operand_matcher_t::per_enc.at(encoding_t::CSRITYPE)},
             {csr_operand_info_t(), csr_operand_matcher_t()},
         }},
};

inline std::vector<operand_description_t>
descriptions4encoding(encoding_t enc) {
  auto &descs = operand_description_t::traits_t::per_enc;
  auto it = descs.find(static_cast<encoding_id_t>(enc));
  CG_ASSERT(it != descs.end(),
            "Operand descriptions for specified encoding wasn't found");
  return it->second;
}

} // namespace cg::riscv

template <> struct cg::opcode_traits<cg::riscv::opcode_t>;

export namespace cg::riscv {
using decoded_inst_t = cg::decoded_inst_t<opcode_t, operand_t>;
} // namespace cg::riscv

template <> struct cg::op_traits<cg::riscv::operand_t> {
  static auto print_visitor(auto &&l) {
    return utils::overloaded(
        [&](cg::riscv::gpr_operand_t gpr) {
          l << '\t' << cg::riscv::gpr_reg_class_t::to_str(gpr.get_reg_id());
        },
        [&](cg::riscv::imm_operand_t imm) { l << '\t' << imm.imm(); },
        [&](cg::riscv::csr_operand_t csr) { l << "\tCSR"; });
  }
};

export namespace cg::riscv {
class opcode_matcher_t final {
  inst_t filter_mask;
  inst_t match_mask;

  template <size_t bitwidth, size_t offset>
  consteval opcode_matcher_t(opcode_encoding_t opcode, funct3 f3,
                             funct_t<bitwidth, offset> f) noexcept
      : filter_mask(opcode.filter() | f3.filter() | f.filter()),
        match_mask(opcode | f3 | f) {}

public:
  consteval opcode_matcher_t(inst_t inst) noexcept
      : filter_mask(~static_cast<inst_t>(0)), match_mask(inst) {}

  template <encoding_t enc>
  static consteval opcode_matcher_t create(opcode_encoding_t opcode, funct3 f3,
                                           funct7 f7) noexcept
    requires(enc != encoding_t::SYSTYPE)
  {
    return opcode_matcher_t(opcode, f3, f7);
  }

  template <encoding_t enc>
  static consteval opcode_matcher_t create(opcode_encoding_t opcode, funct3 f3,
                                           funct12 f12) noexcept
    requires(enc == encoding_t::SYSTYPE)
  {
    return opcode_matcher_t(opcode, f3, f12);
  }

  constexpr bool match(inst_t inst) const noexcept {
    return (inst & filter_mask) == match_mask;
  }

  static const std::unordered_map<opcode_t, opcode_matcher_t> per_opc;
};

static_assert(opcode_matcher_c<opcode_matcher_t, inst_t>);

#define CG_FSIM_RISCV_OPCODE_MATCHER_ITEM(opc, bits, enc, f3, f7ORf12, ...)    \
  {opcode_t::opc, opcode_matcher_t::create<encoding_t::enc>(                   \
                      opcode_bits(opcode_t::opc), f3, f7ORf12)},

inline const std::unordered_map<opcode_t, opcode_matcher_t>
    opcode_matcher_t::per_opc = {
        CG_FSIM_RISCV_RV32I_OPOCDES(CG_FSIM_RISCV_OPCODE_MATCHER_ITEM)
            CG_FSIM_RISCV_RV32M_OPOCDES(CG_FSIM_RISCV_OPCODE_MATCHER_ITEM)
                CG_FSIM_RISCV_ZICSR_OPOCDES(CG_FSIM_RISCV_OPCODE_MATCHER_ITEM)};
} // namespace cg::riscv

template <> struct cg::opcode_traits<cg::riscv::opcode_t> {
  static riscv::opcode_matcher_t matcher(riscv::opcode_t opcode) {
    auto &matchers = riscv::opcode_matcher_t::per_opc;
    auto it = matchers.find(opcode);
    CG_ASSERT(it != matchers.end(),
              "Opcode matcher for specified opcode wasn't found");
    return it->second;
  }

  static auto descriptions(riscv::opcode_t opcode) {
    return descriptions4encoding(encoding4opcode(opcode));
  }

#define CG_FSIM_RISCV_OPCODES_LIST_ITEM(opc, ...) riscv::opcode_t::opc,

  static constexpr std::array opcodes = {
      CG_FSIM_RISCV_RV32I_OPOCDES(CG_FSIM_RISCV_OPCODES_LIST_ITEM)
          CG_FSIM_RISCV_RV32M_OPOCDES(CG_FSIM_RISCV_OPCODES_LIST_ITEM)
              CG_FSIM_RISCV_ZICSR_OPOCDES(CG_FSIM_RISCV_OPCODES_LIST_ITEM)};

#define CG_FSIM_RISCV_OPCODES_TO_STR_ITEM(opc, ...)                            \
  case riscv::opcode_t::opc:                                                   \
    return #opc;

  static constexpr std::string_view to_str(riscv::opcode_t opcode) {
    switch (opcode) {
      CG_FSIM_RISCV_RV32I_OPOCDES(CG_FSIM_RISCV_OPCODES_TO_STR_ITEM)
      CG_FSIM_RISCV_RV32M_OPOCDES(CG_FSIM_RISCV_OPCODES_TO_STR_ITEM)
      CG_FSIM_RISCV_ZICSR_OPOCDES(CG_FSIM_RISCV_OPCODES_TO_STR_ITEM)
    default:
      throw unknown_opcode(opcode);
    }
  }
};

export namespace cg::riscv {

using inst_description_t =
    cg::inst_description_t<opcode_t, inst_t, opcode_matcher_t,
                           operand_description_t>;

using inst_info_t = cg::inst_info_t<inst_description_t>;

inline const inst_info_t inst_info;

inline auto decode(inst_t inst) {
  auto it = std::ranges::find_if(
      inst_info, [inst](const auto &desc) { return desc.match_opc(inst); });
  CG_ASSERT(it != inst_info.end(), "Can't decode specified instruction");
  return decoded_inst_t(it->opcode(), it->operands(inst));
}

enum class mem_op_size_t {
  BYTE,
  HALF,
  WORD,
  UBYTE,
  UHALF,
};

enum class syscall_num_t {
  CLOSE = 57,
  WRITE = 64,
  NEWFSTAT = 80,
  EXIT = 93,
  BRK = 214,
};

enum class trap_cause_t {
  NONE,
  ECALL,
  EBREAK,
};

class simulator_t {
public:
  memory_t memory;
  reg_file_t regs;

private:
  trap_cause_t trap_cause = trap_cause_t::NONE;

  logger_t logger;

  static constexpr size_t rd_idx = 0;
  static constexpr size_t rs1_idx = 1;
  static constexpr size_t rs2_idx = 2;
  static constexpr size_t rs1_no_rd_idx = 0;
  static constexpr size_t rs2_no_rd_idx = 1;

  static constexpr bool dst = true;
  static constexpr bool src = false;

  template <bool is_dst = src> static size_t extract_reg(operand_t op) {
    size_t reg;
    op.visit(
        [&reg](gpr_operand_t reg_op) {
          CG_ASSERT(reg_op.is_dst() == is_dst);
          reg = reg_op.get_reg_id();
        },
        [](auto other_ops) { CG_ASSERT(false); });
    return reg;
  }

  static reg_t extract_imm(operand_t op) {
    reg_t imm;
    op.visit([&imm](imm_operand_t imm_op) { imm = imm_op.imm(); },
             [](auto other_ops) { CG_ASSERT(false); });
    return imm;
  }

  void exec_reg_arithmetic(std::span<const operand_t> ops,
                           std::invocable<reg_t, reg_t> auto &&operation) {
    CG_ASSERT(ops.size() == 3);
    auto rd_op = ops[rd_idx];
    auto rs1_op = ops[rs1_idx];
    auto rs2_op = ops[rs2_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto rs1 = extract_reg(rs1_op);
    auto rs2 = extract_reg(rs2_op);
    auto rs1_val = regs.read(rs1);
    auto rs2_val = regs.read(rs2);
    auto rd_val = operation(rs1_val, rs2_val);
    regs.write(rd, rd_val);
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void exec_imm_arithmetic(std::span<const operand_t> ops,
                           std::invocable<reg_t, reg_t> auto &&operation) {
    CG_ASSERT(ops.size() == 3);
    auto rd_op = ops[rd_idx];
    auto rs1_op = ops[rs1_idx];
    constexpr size_t imm_idx = 2;
    auto imm_op = ops[imm_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto rs1 = extract_reg(rs1_op);
    auto imm = extract_imm(imm_op);
    auto rs1_val = regs.read(rs1);
    auto rd_val = operation(rs1_val, imm);
    regs.write(rd, rd_val);
    regs.set_pc(regs.get_pc() + pc_step);
  }

  reg_t load(addr_t addr, mem_op_size_t size) {
    reg_t data;
    switch (size) {
    default:
      CG_UNREACHABLE("Unknown memory operation size");
    case mem_op_size_t::BYTE:
      data = static_cast<reg_t>(static_cast<byte_t>(memory.read_byte(addr)));
      break;
    case mem_op_size_t::HALF:
      data = static_cast<reg_t>(static_cast<half_t>(memory.read_half(addr)));
      break;
    case mem_op_size_t::WORD:
      data = static_cast<reg_t>(static_cast<word_t>(memory.read_word(addr)));
      break;
    case mem_op_size_t::UBYTE:
      data = to_reg(static_cast<ureg_t>(memory.read_byte(addr)));
      break;
    case mem_op_size_t::UHALF:
      data = to_reg(static_cast<ureg_t>(memory.read_half(addr)));
      break;
    }
    return data;
  }

  void exec_load(std::span<const operand_t> ops, mem_op_size_t size) {
    CG_ASSERT(ops.size() == 3);
    auto rd_op = ops[rd_idx];
    auto rs1_op = ops[rs1_idx];
    constexpr size_t imm_idx = 2;
    auto imm_op = ops[imm_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto rs1 = extract_reg(rs1_op);
    auto imm = extract_imm(imm_op);
    auto addr = to_addr(regs.read(rs1) + imm);
    auto rd_val = load(addr, size);
    regs.write(rd, rd_val);
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void store(addr_t addr, reg_t data, mem_op_size_t size) {
    switch (size) {
    default:
      CG_ASSERT(false);
    case mem_op_size_t::BYTE:
      memory.write_byte(addr, static_cast<ubyte_t>(data & ~ubyte_t{0}));
      break;
    case mem_op_size_t::HALF:
      memory.write_half(addr, static_cast<uhalf_t>(data & ~uhalf_t{0}));
      break;
    case mem_op_size_t::WORD:
      memory.write_word(addr, static_cast<uword_t>(data & ~uword_t{0}));
      break;
    }
  }

  void exec_store(std::span<const operand_t> ops, mem_op_size_t size) {
    CG_ASSERT(ops.size() == 3);
    auto rs1_op = ops[rs1_no_rd_idx];
    auto rs2_op = ops[rs2_no_rd_idx];
    constexpr size_t imm_idx = 2;
    auto imm_op = ops[imm_idx];
    auto rs1 = extract_reg(rs1_op);
    auto rs2 = extract_reg(rs2_op);
    auto imm = extract_imm(imm_op);
    auto addr = to_addr(regs.read(rs1) + imm);
    store(addr, regs.read(rs2), size);
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void exec_branch(std::span<const operand_t> ops,
                   std::invocable<reg_t, reg_t> auto &&comparator) {
    CG_ASSERT(ops.size() == 3);
    auto rs1_op = ops[rs1_no_rd_idx];
    auto rs2_op = ops[rs2_no_rd_idx];
    constexpr size_t imm_idx = 2;
    auto imm_op = ops[imm_idx];
    auto rs1 = extract_reg(rs1_op);
    auto rs2 = extract_reg(rs2_op);
    auto imm = extract_imm(imm_op);
    auto rs1_val = regs.read(rs1);
    auto rs2_val = regs.read(rs2);
    auto taken = comparator(rs1_val, rs2_val);
    auto offset = taken ? imm : pc_step;
    regs.set_pc(regs.get_pc() + offset);
  }

  void exec_jal(std::span<const operand_t> ops) {
    CG_ASSERT(ops.size() == 2);
    auto rd_op = ops[rd_idx];
    constexpr size_t imm_idx = 1;
    auto imm_op = ops[imm_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto imm = extract_imm(imm_op);
    auto rd_val = regs.get_pc() + pc_step;
    regs.write(rd, rd_val);
    regs.set_pc(regs.get_pc() + imm);
  }

  void exec_jalr(std::span<const operand_t> ops) {
    CG_ASSERT(ops.size() == 3);
    auto rd_op = ops[rd_idx];
    auto rs1_op = ops[rs1_idx];
    constexpr size_t imm_idx = 2;
    auto imm_op = ops[imm_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto rs1 = extract_reg(rs1_op);
    auto imm = extract_imm(imm_op);
    auto rd_val = regs.get_pc() + pc_step;
    regs.write(rd, rd_val);
    auto rs1_val = regs.read(rs1);
    regs.set_pc(rs1_val + imm);
  }

  std::unordered_map<int, int> open_fds = {{0, 0}, {1, 1}, {2, 2}};

  void process_close() {
    auto guest_fd = regs.read(gpr_abi_t::a0);
    auto fd_pos = open_fds.find(guest_fd);
    if (fd_pos == open_fds.end()) {
      regs.write(gpr_abi_t::a0, -1);
      return;
    }
    open_fds.erase(fd_pos);
    regs.write(gpr_abi_t::a0, 0);
  }

  void process_write();

  void process_newfstat() {
    regs.write(gpr_abi_t::a0, -1); // unimplemented
  }

  void process_exit() {
    auto ret_val = regs.read(gpr_abi_t::a0);
    std::cerr << "`exit` called. Exiting." << std::endl;
    std::exit(ret_val);
  }

  void process_brk() {
    auto addr = to_addr(regs.read(gpr_abi_t::a0));
    memory.extend_upto(addr);
    regs.write(gpr_abi_t::a0, 0);
  }

  void exec_ecall(std::span<const operand_t> ops) {
    CG_ASSERT(ops.empty());
    auto syscall_num = regs.read(gpr_abi_t::a7);
    switch (static_cast<syscall_num_t>(syscall_num)) {
    default:
      CG_UNREACHABLE(std::format("Unsupported ecall: {}", syscall_num));
    case syscall_num_t::CLOSE:
      process_close();
      break;
    case syscall_num_t::WRITE:
      process_write();
      break;
    case syscall_num_t::NEWFSTAT:
      process_newfstat();
      break;
    case syscall_num_t::EXIT:
      process_exit();
      break;
    case syscall_num_t::BRK:
      process_brk();
      break;
    }
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void exec_ebreak(std::span<const operand_t> ops) {
    CG_ASSERT(ops.empty());
    trap_cause = trap_cause_t::EBREAK;
  }

  void exec_fence(std::span<const operand_t>) {
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void exec_lui(std::span<const operand_t> ops) {
    CG_ASSERT(ops.size() == 2);
    auto rd_op = ops[rd_idx];
    constexpr size_t imm_idx = 1;
    auto imm_op = ops[imm_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto imm = extract_imm(imm_op);
    regs.write(rd, imm);
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void exec_auipc(std::span<const operand_t> ops) {
    CG_ASSERT(ops.size() == 2);
    auto rd_op = ops[rd_idx];
    constexpr size_t imm_idx = 1;
    auto imm_op = ops[imm_idx];
    auto rd = extract_reg<dst>(rd_op);
    auto imm = extract_imm(imm_op);
    regs.write(rd, regs.get_pc() + imm);
    regs.set_pc(regs.get_pc() + pc_step);
  }

  void log_inst(inst_t inst) {
    logger << "0x" << std::hex << std::setw(8) << std::setfill('0')
           << regs.get_pc() << ":\t0x" << std::hex << std::setw(8)
           << std::setfill('0') << inst << "\n"
           << std::dec;
  }

  void log_decoded_inst(const decoded_inst_t &inst) { inst.print(logger); }

  const static std::unordered_map<
      opcode_t, void (*)(simulator_t &, std::span<const operand_t>)>
      i_opc_actions;

  const static std::unordered_map<
      opcode_t, void (*)(simulator_t &, std::span<const operand_t>)>
      c_opc_actions;

  const static std::unordered_map<
      opcode_t, void (*)(simulator_t &, std::span<const operand_t>)>
      m_opc_actions;

public:
  simulator_t(enabled_extensions_t en_exts, logger_t l = cg::null_logger)
      : memory(l), regs(en_exts, l), logger(l) {}

  inst_t fetch_inst() { return memory.read_word(regs.get_pc()); }

  void exec_one() {
    auto inst = fetch_inst();
    log_inst(inst);
    auto decoded_inst = decode(inst);
    log_decoded_inst(decoded_inst);
    auto action_pos = i_opc_actions.find(decoded_inst.opc());
    CG_ASSERT(action_pos != i_opc_actions.end());
    action_pos->second(*this, decoded_inst.ops());
  }

  void exec_from(addr_t start) {
    regs.set_pc(start);
    for (;;) {
      if (trap_cause == trap_cause_t::EBREAK)
        break;
      exec_one();
    }
  }

  void load_section(const char *data, size_t size, addr_t addr) {
    memory.load_section(data, size, addr);
  }

  void init_sp(addr_t sp) { regs.write(gpr_abi_t::sp, sp); }

  friend class uop_processor_t;
};

struct options_t final {
  enabled_extensions_t extensions;
  std::string elf_path;
};

options_t parse_args(int argc, char *argv[]) {
  CG_ASSERT(argc == 3);
  return options_t{.extensions = enabled_extensions_t(argv[1]),
                   .elf_path = argv[2]};
}

void coregear_run(options_t opts);

} // namespace cg::riscv

#ifdef __cplusplus
extern "C" {
#endif
export int coregear_run(int argc, char *argv[])
#ifdef __cplusplus
    noexcept
#endif
    ;
#ifdef __cplusplus
}
#endif

namespace cg::riscv {

namespace uop {
static constexpr auto add_op = std::plus{};
static constexpr auto sub_op = std::minus{};
static constexpr auto or_op = std::bit_or{};
static constexpr auto xor_op = std::bit_xor{};
static constexpr auto and_op = std::bit_and{};
static constexpr auto srl_op = [](reg_t s1, reg_t s2) {
  return to_ureg(s1) >> s2;
};
static constexpr auto sll_op = [](reg_t s1, reg_t s2) {
  return to_ureg(s1) << s2;
};
static constexpr auto sra_op = [](reg_t s1, reg_t s2) { return s1 >> s2; };
static constexpr auto slt_op = [](reg_t s1, reg_t s2) {
  return s1 < s2 ? 1 : 0;
};
static constexpr auto sltu_op = [](reg_t s1, reg_t s2) {
  return to_ureg(s1) < to_ureg(s2) ? 1 : 0;
};

static constexpr auto eq_op = std::equal_to{};
static constexpr auto ne_op = std::not_equal_to{};
static constexpr auto lt_op = std::less{};
static constexpr auto ge_op = std::greater_equal{};
static constexpr auto ltu_op = [](reg_t s1, reg_t s2) {
  return lt_op(to_ureg(s1), to_ureg(s2));
};
static constexpr auto geu_op = [](reg_t s1, reg_t s2) {
  return ge_op(to_ureg(s1), to_ureg(s2));
};

static constexpr auto mul_op = [](reg_t s1, reg_t s2) {
  return to_reg((to_dreg(s1) * to_dreg(s2)) & ~static_cast<reg_t>(0));
};

static constexpr auto mulh_op = [](reg_t s1, reg_t s2) {
  return to_reg((to_dreg(s1) * to_dreg(s2)) >> xlen);
};

static constexpr auto mulhsu_op = [](reg_t s1, reg_t u2) {
  return to_reg((to_dreg(s1) * to_udreg(to_ureg(u2))) >> xlen);
};

static constexpr auto mulhu_op = [](reg_t u1, reg_t u2) {
  return to_reg(
      to_ureg((to_udreg(to_ureg(u1)) * to_udreg(to_ureg(u2))) >> xlen));
};

static constexpr auto div_op = std::divides{};

static constexpr auto divu_op = [](reg_t u1, reg_t u2) {
  return to_reg(div_op(to_ureg(u1), to_ureg(u2)));
};

static constexpr auto rem_op = std::modulus{};

static constexpr auto remu_op = [](reg_t u1, reg_t u2) {
  return to_reg(rem_op(to_ureg(u1), to_ureg(u2)));
};
} // namespace uop

export class uop_processor_t {
public:
  static void add_func(simulator_t &sim, std::span<const operand_t> ops) {
    sim.exec_reg_arithmetic(ops, uop::add_op);
  }

  static void sub_func(simulator_t &sim, std::span<const operand_t> ops) {
    sim.exec_reg_arithmetic(ops, uop::sub_op);
  }

